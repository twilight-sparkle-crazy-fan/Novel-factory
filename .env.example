# 相对路径以项目根目录为准
MODEL_PATH=model/your-model.gguf
LLAMA_SERVER_BIN=llama-server
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8080
APP_HOST=127.0.0.1
APP_PORT=8000

# Apple Silicon 默认由 llama.cpp 自动安排 Metal offload
N_CTX=32768
N_GPU_LAYERS=auto
N_PARALLEL=1
PROMPT_CACHE_MB=512
CACHE_TYPE_K=q8_0
CACHE_TYPE_V=q8_0

# 小说写作默认关闭长思考，避免输出额度全部消耗在 reasoning
REASONING=off
AUTO_START_LLAMA=true
LLAMA_START_TIMEOUT=180

DATABASE_PATH=data/novel-factory.db
MAX_CANDIDATES_PER_EXCHANGE=20
